# Copy this file to `.env` and fill in the values.

PORT=3001
MONGO_URI=mongodb://localhost:27017/employee_management
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# Registration token lifetime (hours)
REGISTRATION_TOKEN_TTL_HOURS=3

# Email (nodemailer) — used for sending registration links & reminders
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="HR Team <hr@example.com>"

# Frontend URL — used when building registration links in emails
FRONTEND_URL=http://localhost:3000
